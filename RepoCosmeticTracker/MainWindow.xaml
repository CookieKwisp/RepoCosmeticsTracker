<Window x:Class="RepoCosmeticTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RepoCosmeticTracker"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        Title="R.E.P.O. Cosmetic Tracker" Height="780" Width="1150"
        MinHeight="520" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <local:RarityBrushConverter x:Key="RarityBrush"/>

        <!-- One cosmetic = one clickable card. A card's entire resting
             appearance — border, icon, name, rarity, owned dim + check
             badge — is pre-baked into one bitmap by CardRenderer at
             startup (and re-baked for a single card on toggle). So this
             template is just that bitmap plus two purely-decorative live
             elements (a hover outline, a transient click "pop" badge) —
             realizing a container during scroll never does layout or text
             work, no matter how many cards are on screen or how fast the
             user scrolls. -->
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="150" Height="182" Margin="7" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="Scale"/>
                            </Grid.RenderTransform>

                            <Image Source="{Binding CardBitmap}" Width="150" Height="182" Stretch="Uniform"/>

                            <Border x:Name="HoverOutline" CornerRadius="12" BorderThickness="2.2"
                                    BorderBrush="{Binding Rarity, Converter={StaticResource RarityBrush}}"
                                    Opacity="0"/>

                            <Border x:Name="CheckBadge" Width="24" Height="24" CornerRadius="12"
                                    Background="{StaticResource SuccessBrush}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,2,2,0" Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="CheckScale" ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock Text="&#x2713;" FontSize="13" FontWeight="Bold" Foreground="#10241A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOutline" Property="Opacity" Value="1"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX"
                                                             To="1.05" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY"
                                                             To="1.05" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX"
                                                             To="0.96" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY"
                                                             To="0.96" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleX"
                                                             To="1.05" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="Scale" Storyboard.TargetProperty="ScaleY"
                                                             To="1.05" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Grid drifts up + fades in on launch -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CardsHost" Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.45"/>
                    <DoubleAnimation Storyboard.TargetName="CardsTranslate" Storyboard.TargetProperty="Y"
                                     From="18" To="0" Duration="0:0:0.45">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Header: title + collection progress ===== -->
        <Grid Grid.Row="0" Margin="22,16,22,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="R.E.P.O." FontSize="20" FontWeight="Black"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text=" COSMETIC TRACKER" FontSize="20" FontWeight="Black"/>
                </StackPanel>
                <TextBlock x:Name="SubtitleText" Text="detecting game&#x2026;" FontSize="11"
                           Foreground="{StaticResource TextDimBrush}" Margin="1,1,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Right">
                    <Run x:Name="OwnedCountRun" Text="0" FontSize="22" FontWeight="Bold"
                         Foreground="{StaticResource AccentBrush}"/><Run Text=" / " FontSize="14"
                         Foreground="{StaticResource TextDimBrush}"/><Run x:Name="TotalCountRun" Text="0"
                         FontSize="14" Foreground="{StaticResource TextDimBrush}"/>
                </TextBlock>
                <Border Width="200" Height="6" CornerRadius="3" Background="#26262E" Margin="0,5,0,0">
                    <Rectangle x:Name="ProgressFill" Width="0" HorizontalAlignment="Left"
                               RadiusX="3" RadiusY="3" Fill="{StaticResource AccentBrush}"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ===== Filter bar: search, rarity chips, category, hide-owned ===== -->
        <DockPanel Grid.Row="1" Margin="22,8,22,10" LastChildFill="False">
            <Grid DockPanel.Dock="Left" Width="230" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Text="Search cosmetics&#x2026;" FontSize="12.5" Margin="32,0,0,0"
                           VerticalAlignment="Center" IsHitTestVisible="False"
                           Foreground="{StaticResource TextDimBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                <ToggleButton x:Name="ChipCommon" Style="{StaticResource Chip}" Tag="Common" Margin="0,0,6,0"
                              Checked="RarityChip_Changed" Unchecked="RarityChip_Changed">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource RarityCommonBrush}" Margin="0,1,6,0"/>
                        <TextBlock Text="Common" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="ChipUncommon" Style="{StaticResource Chip}" Tag="Uncommon" Margin="0,0,6,0"
                              Checked="RarityChip_Changed" Unchecked="RarityChip_Changed">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource RarityUncommonBrush}" Margin="0,1,6,0"/>
                        <TextBlock Text="Uncommon" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="ChipRare" Style="{StaticResource Chip}" Tag="Rare" Margin="0,0,6,0"
                              Checked="RarityChip_Changed" Unchecked="RarityChip_Changed">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource RarityRareBrush}" Margin="0,1,6,0"/>
                        <TextBlock Text="Rare" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="ChipUltraRare" Style="{StaticResource Chip}" Tag="UltraRare" Margin="0,0,10,0"
                              Checked="RarityChip_Changed" Unchecked="RarityChip_Changed">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource RarityUltraRareBrush}" Margin="0,1,6,0"/>
                        <TextBlock Text="Ultra Rare" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                    </StackPanel>
                </ToggleButton>
                <ComboBox x:Name="CategoryCombo" MinWidth="150" SelectionChanged="CategoryCombo_SelectionChanged"/>
            </StackPanel>

            <ToggleButton x:Name="HideOwnedChip" DockPanel.Dock="Right" Style="{StaticResource Chip}"
                          Content="Hide owned" VerticalAlignment="Center"
                          Checked="HideOwned_Changed" Unchecked="HideOwned_Changed"/>
        </DockPanel>

        <!-- ===== Card grid ===== -->
        <Grid Grid.Row="2">
            <!-- ListBox (not ItemsControl-in-ScrollViewer) so UI virtualization
                 works: only visible cards get containers, and recycling reuses
                 them across filter changes. -->
            <ListBox x:Name="CardsHost" Margin="16,2,16,0" Padding="0,0,0,20"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     VirtualizingPanel.CacheLength="1,1"
                     VirtualizingPanel.CacheLengthUnit="Page"
                     ScrollViewer.CanContentScroll="True">
                <ListBox.RenderTransform>
                    <TranslateTransform x:Name="CardsTranslate"/>
                </ListBox.RenderTransform>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <vwp:VirtualizingWrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource CardButton}" Click="Card_Click"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="No cosmetics yet" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Install R.E.P.O. via Steam and run it once &#x2014; the catalog builds itself."
                           FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,7">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="WatchDot" Width="8" Height="8" Fill="#555561" VerticalAlignment="Center">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="1" To="0.3" Duration="0:0:1.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock x:Name="StatusText" Text="Starting&#x2026;" FontSize="11.5" Margin="9,0,0,0"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ToggleButton x:Name="MuteToggle" Style="{StaticResource Chip}" Content="&#x1F50A;" Padding="9,3"
                                  Checked="MuteToggle_Changed" Unchecked="MuteToggle_Changed"/>
                    <Button x:Name="RefreshButton" Style="{StaticResource GhostButton}" Content="&#x21BB; Rescan game files"
                            Margin="8,0,0,0" Click="RefreshButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
