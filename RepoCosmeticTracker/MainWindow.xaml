<Window x:Class="RepoCosmeticTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="REPO Cosmetic Tracker" Height="720" Width="1050"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="10" Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="REPO install:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock x:Name="InstallPathText" Text="(not detected)" VerticalAlignment="Center" Margin="4,0,20,0" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="Save folder:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBlock x:Name="SaveFolderText" Text="(not detected)" VerticalAlignment="Center" Margin="4,0,20,0" TextTrimming="CharacterEllipsis"/>
            <Button x:Name="DetectButton" Content="Detect" Click="DetectButton_Click" Padding="10,3" Margin="0,0,10,0"/>
            <Button x:Name="RefreshCatalogButton" Content="Refresh Catalog (1-click)" Click="RefreshCatalogButton_Click" Padding="10,3"/>
        </StackPanel>

        <TabControl Grid.Row="1">

            <TabItem Header="1. Save Data">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Save slot:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="SaveSlotCombo" Width="300"/>
                        <Button Content="Decrypt slot" Click="DecryptButton_Click" Margin="10,0,0,0" Padding="10,3"/>
                        <Button Content="Open specific file..." Click="OpenSpecificFileButton_Click" Margin="10,0,0,0" Padding="10,3"/>
                        <Button Content="List all .es3 files" Click="ListAllEs3Button_Click" Margin="10,0,0,0" Padding="10,3"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Search decrypted JSON:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="JsonSearchBox" Width="250" TextChanged="JsonSearchBox_TextChanged"/>
                        <TextBlock Text="(try: hat, skin, unlock, cosmetic, item)" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray"/>
                    </StackPanel>

                    <TextBox x:Name="JsonOutputBox" Grid.Row="2"
                             IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </TabItem>

            <TabItem Header="2. Scan Game Assembly">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Keywords:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="KeywordsBox" Width="450"
                                 Text="Cosmetic,Hat,Skin,Outfit,Hair,Accessory,Wearable,Costume"/>
                        <Button Content="Scan" Click="ScanButton_Click" Margin="10,0,0,0" Padding="10,3"/>
                    </StackPanel>
                    <TextBox x:Name="ScanOutputBox" Grid.Row="1"
                             IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </TabItem>

            <TabItem Header="3. Checklist">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Load catalog.json" Click="LoadCatalogButton_Click" Padding="10,3" Margin="0,0,8,0"/>
                        <Button Content="Save changes" Click="SaveCatalogButton_Click" Padding="10,3" Margin="0,0,8,0"/>
                        <Button Content="Import from AssetRipper export..." Click="ImportFromAssetRipperButton_Click" Padding="10,3" Margin="0,0,8,0"/>
                        <Button Content="Import with Numeric IDs..." Click="ImportWithNumericIdsButton_Click" Padding="10,3" Margin="0,0,8,0"/>
                        <Button Content="Sync ownership from opened file" Click="SyncOwnershipButton_Click" Padding="10,3"/>
                        <TextBlock x:Name="CatalogStatusText" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" x:Name="CosmeticsGrid" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Owned" Binding="{Binding Owned, Mode=TwoWay}" Width="60"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Numeric Id" Binding="{Binding NumericId}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="4. Find in Export">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Export folder:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="ExportFolderText" Text="(not selected)" VerticalAlignment="Center"
                                   Width="420" TextTrimming="CharacterEllipsis"/>
                        <Button Content="Browse..." Click="BrowseExportFolderButton_Click" Padding="10,3" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Keyword:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="AssetSearchKeywordBox" Width="220" Text="cosmeticAssets:"/>
                        <TextBlock Text="Extensions:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <TextBox x:Name="AssetSearchExtensionsBox" Width="220" Text="prefab,unity,asset"/>
                        <Button x:Name="AssetSearchButton" Content="Search" Click="AssetSearchButton_Click" Padding="10,3" Margin="10,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Extract list — file:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="ExtractFilePathBox" Width="420"/>
                        <TextBlock Text="field:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <TextBox x:Name="ExtractFieldNameBox" Width="140" Text="cosmeticAssets"/>
                        <Button Content="Extract" Click="ExtractBlockButton_Click" Padding="10,3" Margin="10,0,0,0"/>
                    </StackPanel>

                    <TextBox x:Name="AssetSearchResultsBox" Grid.Row="3"
                             IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
